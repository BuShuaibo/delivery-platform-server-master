<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.neu.deliveryPlatform.mapper.PermissionMapper">
    <resultMap id="BaseResultMap" type="com.neu.deliveryPlatform.entity.Permission">
        <id property="id" column="id" jdbcType="INTEGER"/>
        <result property="permissionKey" column="perm_key" jdbcType="VARCHAR"/>
        <result property="name" column="name" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,perm_key,name
    </sql>
    <insert id="addPermission">
        insert into sys_menu (perm_key,name) values (#{permissionKey},#{name})
    </insert>
</mapper>